    "test": "node --experimental-specifier-resolution=node --loader ts-node/esm src/matching.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "dotenv": "^16.4.7",
    "hono": "^4.12.0",
    "mongoose": "^8.9.0",
    "nanoid": "^5.0.9",
    "pino": "9.7.0",
    "pino-pretty": "13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
