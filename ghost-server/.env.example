# v0 JSON-file storage (default)
DATA_FILE=./data/ghost-data.json

# Pool address surfaced at GET /health
POOL_ADDRESS=

# MongoDB (unused in v0 — kept for future swap-in).
# NEVER commit a real connection string. Keep secrets only in a gitignored .env.
# MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/ghost?retryWrites=true&w=majority

# HTTP server port
PORT=8080

# Matching epoch duration in ms
EPOCH_MS=5000

# Log level: trace|debug|info|warn|error
LOG_LEVEL=info
